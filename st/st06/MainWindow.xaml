<Window
    x:Class="ST06.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:ST06"
    mc:Ignorable="d"
    Title="MainWindow"
    Height="450"
    Width="800">
    <!-- Window.DataContext 定义了窗口的数据上下文 -->
    <Window.DataContext>
        <!-- 创建 ViewModel 实例 -->
        <local:ViewModel/>
    </Window.DataContext>
    <Grid>
        <!-- Binding Volume 表示数据绑定到 Volume 属性 -->
        <!-- UpdateSourceTrigger=PropertyChanged 表示在属性更改时更新源 -->
        <!-- VerticalAlignment="Top" 表示控件在垂直方向上对齐到顶部 -->
        <TextBox
            x:Name="InputTextBox"
            HorizontalAlignment="Left"
            Height="23"
            Margin="10,10,0,0"
            TextWrapping="Wrap"
            Text="{Binding Volume, UpdateSourceTrigger=PropertyChanged}"
            VerticalAlignment="Top"
            Width="200"/>
        <Slider
            x:Name="FontSizeSlider"
            HorizontalAlignment="Left"
            Margin="10,40,0,0"
            VerticalAlignment="Top"
            Width="200"
            Minimum="0"
            Maximum="150"
            Value="{Binding Volume, UpdateSourceTrigger=PropertyChanged}"/>

        <!-- 名称输入 -->
        <TextBox
            x:Name="InputTextBoxName"
            HorizontalAlignment="Left"
            Height="23"
            Margin="10,80,0,0"
            TextWrapping="Wrap"
            Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
            VerticalAlignment="Top"
            Width="200"/>
        <TextBlock
            HorizontalAlignment="Left"
            Margin="10,110,0,0"
            VerticalAlignment="Top"
            Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
    </Grid>
</Window>
