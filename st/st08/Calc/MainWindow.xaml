<Window
  x:Class="Calc.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:Calc"
  Title="Calc"
  Height="640"
  Width="420">

  <!-- 在数据上下文添加 ViewModel 层 -->
  <Window.DataContext>
    <local:ViewModel/>
  </Window.DataContext>

  <!-- 样式定义 -->
  <Window.Resources>

    <Style TargetType="Button">
      <Setter
        Property="FontSize"
        Value="64"/>
      <Setter
        Property="Margin"
        Value="1"/>
    </Style>

    <Style TargetType="TextBlock">
      <Setter
        Property="FontSize"
        Value="64"/>
      <Setter
        Property="TextAlignment"
        Value="Right"/>
      <Setter
        Property="Margin"
        Value="1"/>
    </Style>

  </Window.Resources>

  <!-- 网格布局 -->
  <Grid
    Height="600"
    Width="400">

    <!-- 行列定义（8行4列） -->
    <Grid.RowDefinitions>
      <RowDefinition/>
      <RowDefinition/>
      <RowDefinition/>
      <RowDefinition/>
      <RowDefinition/>
      <RowDefinition/>
      <RowDefinition/>
      <RowDefinition/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition/>
      <ColumnDefinition/>
      <ColumnDefinition/>
      <ColumnDefinition/>
    </Grid.ColumnDefinitions>

    <!-- 显示结果的文本块 -->
    <TextBlock
      Text="{Binding Expression}"
      Grid.Row="0"
      Grid.Column="0"
      Grid.ColumnSpan="4"
      Foreground="Red"
      Background="LightGreen"/>
    <TextBlock
      Text="{Binding Result}"
      Grid.Row="1"
      Grid.Column="0"
      Grid.ColumnSpan="4"
      Background="LightPink"/>


    <!-- 操作按钮 -->
    <Button
      Grid.Row="2"
      Grid.Column="0"
      Content="="
      Command="{Binding ReplaceCommand}"/>
    <Button
      Grid.Row="2"
      Grid.Column="3"
      Content="Backspace"
      Command="{Binding DeleteCharCommand}"/>
    <Button
      Grid.Row="3"
      Grid.Column="0"
      Content="C"
      Command="{Binding ClearCommand}"/>
    <Button
      Grid.Row="6"
      Grid.Column="3"
      Grid.RowSpan="2"
      Content="Enter"
      Command="{Binding ReplaceCommand}"/>


    <!-- 字符按钮 -->
    <!-- Row 2 -->
    <Button
      Grid.Row="2"
      Grid.Column="1"
      Content="("
      Command="{Binding EnterCharCommand}"
      CommandParameter="("/>
    <Button
      Grid.Row="2"
      Grid.Column="2"
      Content=")"
      Command="{Binding EnterCharCommand}"
      CommandParameter=")"/>

    <!-- Row 3 -->
    <Button
      Grid.Row="3"
      Grid.Column="1"
      Content="/"
      Command="{Binding EnterCharCommand}"
      CommandParameter="/"/>
    <Button
      Grid.Row="3"
      Grid.Column="2"
      Content="*"
      Command="{Binding EnterCharCommand}"
      CommandParameter="*"/>
    <Button
      Grid.Row="3"
      Grid.Column="3"
      Content="-"
      Command="{Binding EnterCharCommand}"
      CommandParameter="-"/>

    <!-- Row 4 -->
    <Button
      Grid.Row="4"
      Grid.Column="0"
      Content="7"
      Command="{Binding EnterCharCommand}"
      CommandParameter="7"/>
    <Button
      Grid.Row="4"
      Grid.Column="1"
      Content="8"
      Command="{Binding EnterCharCommand}"
      CommandParameter="8"/>
    <Button
      Grid.Row="4"
      Grid.Column="2"
      Content="9"
      Command="{Binding EnterCharCommand}"
      CommandParameter="9"/>
    <Button
      Grid.Row="4"
      Grid.Column="3"
      Grid.RowSpan="2"
      Content="+"
      Command="{Binding EnterCharCommand}"
      CommandParameter="+"/>

    <!-- Row 5 -->
    <Button
      Grid.Row="5"
      Grid.Column="0"
      Content="4"
      Command="{Binding EnterCharCommand}"
      CommandParameter="4"/>
    <Button
      Grid.Row="5"
      Grid.Column="1"
      Content="5"
      Command="{Binding EnterCharCommand}"
      CommandParameter="5"/>
    <Button
      Grid.Row="5"
      Grid.Column="2"
      Content="6"
      Command="{Binding EnterCharCommand}"
      CommandParameter="6"/>

    <!-- Row 6 -->
    <Button
      Grid.Row="6"
      Grid.Column="0"
      Content="1"
      Command="{Binding EnterCharCommand}"
      CommandParameter="1"/>
    <Button
      Grid.Row="6"
      Grid.Column="1"
      Content="2"
      Command="{Binding EnterCharCommand}"
      CommandParameter="2"/>
    <Button
      Grid.Row="6"
      Grid.Column="2"
      Content="3"
      Command="{Binding EnterCharCommand}"
      CommandParameter="3"/>

    <!-- Row 7 -->
    <Button
      Grid.Row="7"
      Grid.Column="0"
      Grid.ColumnSpan="2"
      Content="0"
      Command="{Binding EnterCharCommand}"
      CommandParameter="0"/>
    <Button
      Grid.Row="7"
      Grid.Column="2"
      Content="."
      Command="{Binding EnterCharCommand}"
      CommandParameter="."/>
  </Grid>
</Window>